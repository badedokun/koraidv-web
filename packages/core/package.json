{
  "name": "@koraidv/core",
  "version": "1.2.0",
  "description": "Kora IDV Core SDK - API Client and Utilities",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {},
  "keywords": [
    "identity-verification",
    "kyc",
    "koraidv",
    "sdk"
  ],
  "author": "Kora IDV <support@koraidv.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koraidv/koraidv-web"
  }
}
