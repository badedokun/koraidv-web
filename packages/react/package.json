{
  "name": "@koraidv/react",
  "version": "1.4.0",
  "description": "Kora IDV React Components for Identity Verification",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch --external react",
    "test": "vitest run"
  },
  "dependencies": {
    "@koraidv/core": "^1.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "keywords": [
    "identity-verification",
    "kyc",
    "koraidv",
    "react",
    "sdk"
  ],
  "author": "Kora IDV <support@koraidv.com>",
  "license": "MIT"
}
